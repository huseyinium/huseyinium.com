    "@upstash/redis": "^1.38.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/og": "^0.11.1",
    "cal-sans": "^1.0.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "framer-motion": "^12.40.0",
    "gray-matter": "^4.0.3",
    "lucide-react": "^1.18.0",
    "motion": "^12.23.12",
    "next": "16.2.9",
    "next-sitemap": "^4.2.3",
