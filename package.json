    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/three": "^0.184.1",
    "@vitejs/plugin-react": "4",
    "eslint": "9",
    "happy-dom": "^20.10.3",
    "husky": "^9.1.7",
